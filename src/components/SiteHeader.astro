---
import { siteContent } from '../data/site';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__logo" href="#uvod" aria-label="WAVE Marketing úvod">
      <img src={siteContent.assets.logo} alt="WAVE Marketing logo" width="180" height="120" />
    </a>
    <nav class="site-header__desktop-nav" aria-label="Hlavní navigace">
      {siteContent.navigation.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <details class="site-header__mobile-nav">
      <summary aria-label="Otevřít hlavní navigaci">Menu</summary>
      <nav aria-label="Mobilní navigace">
        {siteContent.navigation.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    background: var(--ds-color-surface-glass);
    backdrop-filter: blur(8px);
    border-bottom: var(--ds-border-width) solid var(--ds-color-border);
    box-shadow: var(--ds-shadow-sm);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-header__inner {
    align-items: center;
    display: flex;
    gap: var(--ds-space-6);
    justify-content: space-between;
    min-height: 96px;
    padding-block: var(--ds-space-3);
  }

  .site-header__logo img {
    height: 72px;
    object-fit: contain;
    width: auto;
  }

  .site-header__desktop-nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--ds-space-6);
    justify-content: flex-end;
  }

  .site-header__desktop-nav a,
  .site-header__mobile-nav a {
    color: var(--ds-color-text-muted);
    font-weight: var(--ds-font-weight-medium);
    text-decoration: none;
  }

  .site-header__desktop-nav a:hover,
  .site-header__mobile-nav a:hover {
    color: var(--ds-color-secondary);
  }

  .site-header__mobile-nav {
    display: none;
    position: relative;
  }

  .site-header__mobile-nav summary {
    border: var(--ds-border-width) solid var(--ds-color-border);
    border-radius: var(--ds-radius-full);
    color: var(--ds-color-primary);
    cursor: pointer;
    font-weight: var(--ds-font-weight-medium);
    list-style: none;
    padding: var(--ds-space-3) var(--ds-space-5);
  }

  .site-header__mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .site-header__mobile-nav summary:focus-visible {
    outline: 3px solid var(--ds-color-secondary);
    outline-offset: 3px;
  }

  .site-header__mobile-nav nav {
    background: var(--ds-color-surface);
    border: var(--ds-border-width) solid var(--ds-color-border);
    border-radius: var(--ds-radius-xl);
    box-shadow: var(--ds-shadow-md);
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-3);
    margin-top: var(--ds-space-3);
    min-width: 180px;
    padding: var(--ds-space-4);
    position: absolute;
    right: 0;
  }

  @media (max-width: 720px) {
    .site-header__inner {
      align-items: center;
      min-height: auto;
    }

    .site-header__logo img {
      height: 60px;
    }

    .site-header__desktop-nav {
      display: none;
    }

    .site-header__mobile-nav {
      display: block;
    }
  }
</style>
