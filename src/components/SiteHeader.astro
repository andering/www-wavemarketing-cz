---
import { siteContent } from '../data/site';

const referenceIndex = siteContent.navigation.findIndex((item) => item.label === 'Reference');
const leftNavigation = siteContent.navigation.slice(0, referenceIndex);
const rightNavigation = siteContent.navigation.slice(referenceIndex);
const socialIconPaths = {
  Facebook: 'M22.675 0h-21.35C.593 0 0 .593 0 1.325v21.351C0 23.407.593 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116C23.407 24 24 23.407 24 22.675V1.325C24 .593 23.407 0 22.675 0z',
  Instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12s.014 3.668.072 4.948c.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24s3.668-.014 4.948-.072c4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948s-.014-3.667-.072-4.947c-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838A6.162 6.162 0 1 0 12 18.163 6.162 6.162 0 0 0 12 5.838zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z',
  LinkedIn: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.447-2.136 2.941v5.665H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM7.119 20.452H3.554V9h3.565v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.226.792 24 1.771 24h20.451C23.2 24 24 23.226 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
} as const;
---

<input class="site-header__menu-toggle" id="site-header-menu-toggle" type="checkbox" aria-label="Otevřít hlavní navigaci" />
<header class="site-header">
  <div class="container site-header__inner">
    <nav class="site-header__desktop-nav" aria-label="Hlavní navigace">
      <div class="site-header__nav-group site-header__nav-group--left">
        {leftNavigation.map((item) => (
          <a href={item.href} data-nav-link={item.href}>{item.label}</a>
        ))}
      </div>
      <a class="site-header__logo site-header__logo-wrap" href="#uvod" aria-label="WAVE Marketing úvod">
        <img src={siteContent.assets.logo} alt="WAVE Marketing logo" width="180" height="120" />
      </a>
      <div class="site-header__nav-group site-header__nav-group--right">
        {rightNavigation.map((item) => (
          <a href={item.href} data-nav-link={item.href}>{item.label}</a>
        ))}
        <div class="site-header__socials" aria-label="Sociální sítě">
          {siteContent.socialLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label} style={`--social-color: ${item.brandColor}`}>
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d={socialIconPaths[item.label]}></path>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </nav>
    <a class="site-header__logo site-header__logo--mobile" href="#uvod" aria-label="WAVE Marketing úvod">
      <img src={siteContent.assets.logo} alt="WAVE Marketing logo" width="180" height="120" />
    </a>
    <label class="site-header__mobile-nav" for="site-header-menu-toggle" role="button" aria-label="Otevřít hlavní navigaci">
      <span class="site-header__hamburger" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span class="site-header__mobile-nav-text">Menu</span>
    </label>
  </div>
</header>
<div class="site-header__offcanvas">
  <label class="site-header__offcanvas-backdrop" for="site-header-menu-toggle" aria-label="Zavřít hlavní navigaci"></label>
  <div class="site-header__offcanvas-panel" role="dialog" aria-label="Mobilní navigace">
    <div class="site-header__offcanvas-heading">
      <strong>Menu</strong>
      <label class="site-header__offcanvas-close" for="site-header-menu-toggle" role="button">Zavřít</label>
    </div>
    <nav aria-label="Mobilní navigace">
      {siteContent.navigation.map((item) => (
        <a href={item.href} data-nav-link={item.href}>{item.label}</a>
      ))}
    </nav>
    <div class="site-header__offcanvas-socials" aria-label="Sociální sítě">
      {siteContent.socialLinks.map((item) => (
        <a href={item.href} target="_blank" rel="noreferrer" aria-label={item.label} style={`--social-color: ${item.brandColor}`}>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d={socialIconPaths[item.label]}></path>
          </svg>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .site-header {
    background: var(--ds-color-surface-glass);
    backdrop-filter: blur(8px);
    border-bottom: var(--ds-border-width) solid var(--ds-color-border);
    box-shadow: var(--ds-shadow-sm);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .site-header__menu-toggle {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .site-header__inner {
    align-items: center;
    display: grid;
    height: 100px;
    max-height: 100px;
    padding-block: 0;
  }

  .site-header__logo img {
    height: 72px;
    object-fit: contain;
    width: auto;
  }

  .site-header__logo--mobile {
    display: none;
  }

  .site-header__desktop-nav {
    align-items: center;
    display: grid;
    gap: var(--ds-space-10);
    grid-template-columns: 1fr auto 1fr;
    position: relative;
    justify-self: stretch;
  }

  .site-header__nav-group {
    align-items: center;
    display: flex;
    gap: var(--ds-space-6);
  }

  .site-header__nav-group--left {
    justify-content: flex-end;
  }

  .site-header__nav-group--right {
    justify-content: flex-start;
  }

  .site-header__desktop-nav a,
  .site-header__offcanvas-panel a {
    color: var(--ds-color-text-muted);
    font-weight: var(--ds-font-weight-medium);
    text-decoration: none;
  }

  .site-header__socials,
  .site-header__offcanvas-socials {
    align-items: center;
    display: flex;
    gap: var(--ds-space-2);
  }

  .site-header__socials {
    border-left: var(--ds-border-width) solid var(--ds-color-border);
    padding-left: var(--ds-space-6);
    position: absolute;
    right: 0;
  }

  .site-header__socials a,
  .site-header__offcanvas-socials a {
    align-items: center;
    color: var(--social-color);
    display: inline-flex;
    height: 24px;
    justify-content: center;
    transition: color var(--ds-duration-fast) var(--ds-ease-standard), transform var(--ds-duration-fast) var(--ds-ease-standard);
    width: 24px;
  }

  .site-header__socials svg,
  .site-header__offcanvas-socials svg {
    display: block;
    fill: currentColor;
    height: 20px;
    width: 20px;
  }

  .site-header__socials a:hover,
  .site-header__offcanvas-socials a:hover {
    color: var(--ds-color-secondary);
    transform: translateY(-1px);
  }

  .site-header__desktop-nav a:hover,
  .site-header__offcanvas-panel a:hover {
    color: var(--ds-color-secondary);
  }

  .site-header__desktop-nav a[data-active="true"],
  .site-header__offcanvas-panel a[data-active="true"] {
    color: var(--ds-color-secondary);
    font-weight: var(--ds-font-weight-bold);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.35em;
  }

  .site-header__mobile-nav {
    align-items: center;
    border: var(--ds-border-width) solid var(--ds-color-border);
    border-radius: var(--ds-radius-full);
    color: var(--ds-color-primary);
    cursor: pointer;
    display: none;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: var(--ds-space-3);
  }

  .site-header__hamburger {
    display: grid;
    gap: 4px;
  }

  .site-header__hamburger span {
    background: currentColor;
    border-radius: var(--ds-radius-full);
    display: block;
    height: 2px;
    width: 20px;
  }

  .site-header__mobile-nav-text {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .site-header__menu-toggle:focus-visible + .site-header .site-header__mobile-nav {
    outline: 3px solid var(--ds-color-secondary);
    outline-offset: 3px;
  }

  .site-header__offcanvas {
    inset: 0;
    pointer-events: none;
    position: fixed;
    transition: visibility 0s var(--ds-duration-normal);
    visibility: hidden;
    z-index: 20;
  }

  .site-header__offcanvas-backdrop {
    background: rgba(0, 59, 61, 0.24);
    inset: 0;
    opacity: 0;
    position: fixed;
    transition: opacity var(--ds-duration-normal) var(--ds-ease-standard);
  }

  .site-header__offcanvas-panel {
    align-content: start;
    background: var(--ds-color-surface);
    border-left: var(--ds-border-width) solid var(--ds-color-border);
    box-shadow: var(--ds-shadow-lg);
    display: grid;
    gap: var(--ds-space-6);
    height: 100dvh;
    inset: 0 0 0 auto;
    max-width: min(360px, 86vw);
    padding: var(--ds-space-8);
    position: fixed;
    transform: translateX(100%);
    transition: transform var(--ds-duration-normal) var(--ds-ease-standard);
    width: 100%;
  }

  .site-header__offcanvas-heading {
    align-items: center;
    border-bottom: var(--ds-border-width) solid var(--ds-color-border);
    display: flex;
    justify-content: space-between;
    padding-bottom: var(--ds-space-6);
  }

  .site-header__offcanvas-panel strong {
    color: var(--ds-color-primary);
    font-family: var(--ds-font-heading);
    font-size: var(--ds-text-2xl);
  }

  .site-header__offcanvas-close {
    color: var(--ds-color-text-muted);
    cursor: pointer;
    font-size: var(--ds-text-sm);
    font-weight: var(--ds-font-weight-medium);
  }

  .site-header__offcanvas-panel nav {
    align-content: start;
    display: grid;
    gap: var(--ds-space-4);
  }

  .site-header__offcanvas-socials {
    border-top: var(--ds-border-width) solid var(--ds-color-border);
    padding-top: var(--ds-space-6);
  }

  .site-header__menu-toggle:checked ~ .site-header__offcanvas {
    pointer-events: auto;
    transition-delay: 0s;
    visibility: visible;
  }

  .site-header__menu-toggle:checked ~ .site-header__offcanvas .site-header__offcanvas-backdrop {
    opacity: 1;
  }

  .site-header__menu-toggle:checked ~ .site-header__offcanvas .site-header__offcanvas-panel {
    transform: translateX(0);
  }

  @media (max-width: 720px) {
    .site-header__inner {
      align-items: center;
      display: flex;
      height: auto;
      justify-content: space-between;
      max-height: none;
      min-height: auto;
      padding-block: var(--ds-space-2);
    }

    .site-header__logo img {
      height: 48px;
    }

    .site-header__logo--mobile {
      display: inline-flex;
    }

    .site-header__desktop-nav {
      display: none;
    }

    .site-header__mobile-nav {
      display: inline-flex;
    }
  }
</style>

<script>
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"));
  const sectionIds = [...new Set(navLinks.map((link) => link.hash).filter(Boolean))];
  const sections = sectionIds
    .map((hash) => document.querySelector<HTMLElement>(hash))
    .filter((section): section is HTMLElement => Boolean(section));

  const updateActiveNavigation = (activeHash: string) => {
    navLinks.forEach((link) => {
      const isActive = link.hash === activeHash;

      if (isActive) {
        link.dataset.active = "true";
        link.setAttribute("aria-current", "page");
      } else {
        delete link.dataset.active;
        link.removeAttribute("aria-current");
      }
    });
  };

  const getCurrentSectionHash = () => {
    const headerOffset = 130;
    let currentHash = sections[0] ? `#${sections[0].id}` : "";

    sections.forEach((section) => {
      if (section.getBoundingClientRect().top <= headerOffset) {
        currentHash = `#${section.id}`;
      }
    });

    return currentHash;
  };

  const updateFromViewport = () => {
    const currentHash = getCurrentSectionHash();

    if (currentHash) {
      updateActiveNavigation(currentHash);
    }
  };

  if (sections.length > 0) {
    const observer = new IntersectionObserver(updateFromViewport, {
      rootMargin: "-25% 0px -60% 0px",
      threshold: 0,
    });

    sections.forEach((section) => observer.observe(section));
    window.addEventListener("hashchange", () => {
      if (sectionIds.includes(window.location.hash)) {
        updateActiveNavigation(window.location.hash);
      }

      window.requestAnimationFrame(updateFromViewport);
    });
    window.addEventListener("load", updateFromViewport, { once: true });
    updateFromViewport();
  }
</script>
