---
import { siteContent } from '../data/site';
---

<section class="contact section" id="kontakt" aria-labelledby="contact-heading">
  <div class="container contact__wrap">
    <div class="contact__header">
      <h2 id="contact-heading">{siteContent.contact.heading}</h2>
      <p class="lead">{siteContent.contact.intro}</p>
    </div>
    <div class="contact__module">
      <article class="contact__person-card">
        <div class="contact__person-head">
          <div class="contact__avatar-wrap">
            <img src={siteContent.assets.janaPhoto} alt="Jana Skalníková" width="180" height="180" />
            <span class="contact__status-dot" aria-hidden="true"></span>
          </div>
          <div class="contact__person-meta">
            <h3>{siteContent.contact.person.name}</h3>
            <p>{siteContent.contact.person.role}</p>
            <a class="contact__phone-number" href={siteContent.contact.person.phoneHref}>
              {siteContent.contact.person.phoneDisplay}
            </a>
          </div>
        </div>
        <a class="button button-secondary contact__phone" href={siteContent.contact.person.phoneHref}>
          {siteContent.contact.person.phoneLabel}
        </a>
      </article>
      <article class="contact__quick-actions contact__email-card">
          <a href={siteContent.contact.email.href}>
            <span class="material-symbols-outlined" aria-hidden="true">mail</span>
            <span class="contact__action-copy">
              <span>{siteContent.contact.email.label}</span>
              <small>{siteContent.contact.email.display}</small>
            </span>
          </a>
      </article>
      <article class="contact__quick-actions contact__availability-card">
        <span class="material-symbols-outlined" aria-hidden="true">groups</span>
        <div>
          <strong>Kde se můžeme vidět</strong>
          <p class="contact__meeting">{siteContent.contact.meeting}</p>
        </div>
      </article>
      <div class="contact__facts-strip" aria-label="Fakturační údaje">
        {siteContent.contact.company.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: radial-gradient(circle at 50% 30%, rgba(116, 89, 60, 0.09), var(--ds-color-background) 62%);
    scroll-margin-top: 112px;
  }

  .contact__wrap {
    max-width: 880px;
  }

  .contact__header {
    margin-bottom: var(--ds-space-12);
    text-align: center;
  }

  .contact h2 {
    color: var(--ds-color-primary);
    font-family: var(--ds-font-heading);
    font-size: clamp(var(--ds-text-3xl), 4vw, var(--ds-text-5xl));
  }

  .contact__module {
    display: grid;
    gap: var(--ds-space-5);
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .contact__person-card,
  .contact__quick-actions {
    background: color-mix(in srgb, var(--ds-color-surface-raised) 70%, transparent);
    border: var(--ds-border-width) solid color-mix(in srgb, var(--ds-color-surface-raised) 80%, transparent);
    border-radius: var(--ds-radius-2xl);
    box-shadow: var(--ds-shadow-lg);
    color: var(--ds-color-primary);
    padding: var(--ds-space-6);
  }

  .contact__person-card {
    display: grid;
    gap: var(--ds-space-5);
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .contact__email-card,
  .contact__availability-card {
    grid-column: 3 / 5;
  }

  .contact__person-head {
    align-items: center;
    display: flex;
    gap: var(--ds-space-5);
  }

  .contact__avatar-wrap {
    position: relative;
  }

  .contact__avatar-wrap img {
    border: 4px solid var(--ds-color-surface-raised);
    border-radius: var(--ds-radius-full);
    box-shadow: var(--ds-shadow-md);
    display: block;
    height: 80px;
    object-fit: cover;
    width: 80px;
  }

  .contact__status-dot {
    background: var(--ds-color-success);
    border: 3px solid var(--ds-color-surface-raised);
    border-radius: var(--ds-radius-full);
    bottom: 4px;
    height: 16px;
    position: absolute;
    right: 4px;
    width: 16px;
  }

  .contact__person-card h3 {
    font-family: var(--ds-font-heading);
    font-size: var(--ds-text-2xl);
    margin: 0 0 var(--ds-space-2);
  }

  .contact__person-card p,
  .contact__person-card small,
  .contact__meeting,
  .contact__facts-strip span {
    color: var(--ds-color-text-muted);
  }

  .contact__person-meta p {
    margin: 0 0 var(--ds-space-2);
  }

  .contact__phone-number {
    color: var(--ds-color-primary);
    display: inline-flex;
    font-size: var(--ds-text-sm);
    font-weight: var(--ds-font-weight-medium);
    text-decoration: none;
  }

  .contact__phone {
    justify-content: center;
  }

  .contact__quick-actions {
    align-items: center;
    display: flex;
    gap: var(--ds-space-4);
    text-decoration: none;
  }

  .contact__quick-actions a {
    align-items: center;
    color: inherit;
    display: flex;
    gap: var(--ds-space-4);
    text-decoration: none;
    width: 100%;
  }

  .contact__quick-actions .material-symbols-outlined {
    align-items: center;
    background: var(--ds-color-secondary);
    border-radius: var(--ds-radius-full);
    color: var(--ds-color-secondary-foreground);
    display: inline-flex;
    flex: 0 0 auto;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .contact__action-copy {
    display: grid;
    gap: var(--ds-space-1);
  }

  .contact__action-copy small {
    color: var(--ds-color-text-muted);
  }

  .contact__availability-card strong {
    display: block;
    margin-bottom: var(--ds-space-2);
  }

  .contact__meeting {
    margin: 0;
  }

  .contact__facts-strip {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ds-space-3) var(--ds-space-5);
    grid-column: 1 / 5;
    justify-content: center;
    text-align: center;
  }

  .contact__facts-strip span {
    font-size: var(--ds-text-sm);
  }

  @media (max-width: 900px) {
    .contact__module {
      grid-template-columns: 1fr;
    }

    .contact__person-card,
    .contact__email-card,
    .contact__availability-card,
    .contact__facts-strip {
      grid-column: 1;
      grid-row: auto;
    }

    .contact__person-head,
    .contact__quick-actions,
    .contact__quick-actions a {
      align-items: center;
      flex-direction: column;
      text-align: center;
    }

    .contact__action-copy {
      justify-items: center;
    }
  }
</style>
